# RAG Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
EMBEDDING_BATCH_SIZE=10
